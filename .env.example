# .env — API key configuration
# Copy this file, rename it to .env, and fill in your keys.
# This file is automatically loaded by config.py at startup.
# NEVER commit your actual .env file to version control.

# Get a free key at https://openweathermap.org/api (free tier: 60 calls/min)
WEATHER_API_KEY=YOUR_OPENWEATHERMAP_KEY_HERE

# Get a free key at https://newsapi.org (free tier: 100 requests/day)
NEWS_API_KEY=YOUR_NEWSAPI_KEY_HERE

# Get a key at https://console.anthropic.com (pay-per-use, ~$0.003 per reply)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE
